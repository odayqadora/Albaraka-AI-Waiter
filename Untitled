if __name__ == "__main__":
    # تجربة سريعة للنادل الغزاوي عند تشغيل الملف محلياً
    llm = Ollama(model="qwen3:8b")
    prompt = "رد كأنك نادل غزاوي يرحب بزبون ويقترح مسخن"
    
    print("⏳ جاري استدعاء النادل... (9060 XT Power!)")
